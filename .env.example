# Local secrets.
#
#   cp .env.example .env
#
# .env is gitignored; this template is the checked-in copy. Loaded automatically by the API at
# start-up, by the test suite, and by docker compose for variable substitution — so nothing here
# needs exporting into your shell.
#
# Secrets only. Anything that is an address, a port, a label, or a value every developer sets
# identically is configuration, not a secret, and belongs in source control:
#
#   * application settings  -> src/Lakehold.Api/appsettings*.json  (telemetry, CDC, maintenance)
#   * service ports/users   -> compose.yaml, which carries its own defaults
#
# Keeping this file small is the point: the shorter it is, the easier it is to see that everything
# in it genuinely had to be kept out of the repository.
#
# These particular values are throwaway credentials for local containers on loopback ports. Replacing
# them is optional locally and mandatory anywhere else.

# ---------------------------------------------------------------------------
# Backing service credentials (read by compose.yaml)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=lakehold
MINIO_ROOT_PASSWORD=lakehold123

# ---------------------------------------------------------------------------
# Integration tests
#
# Each suite is gated on its variable and skips when unset, so `dotnet test` needs no services by
# default. Filling these in is what opts you into running them — after `docker compose up -d`.
# Comment a block out to go back to skipping it.
#
# The non-secret half of each block (endpoint, bucket) lives here rather than in appsettings because
# the tests read the process environment directly, and because the gate only means anything
# alongside the credential it authenticates with.
# ---------------------------------------------------------------------------

# PostgreSQL-backed catalog metadata. A libpq connection string, not a .NET one.
LAKEHOLD_TEST_POSTGRES=dbname=lakeholdmeta host=localhost port=55439 user=lakehold password=lakehold

# S3-compatible object store. The bucket is created by the minio-bucket service in compose.yaml;
# the tests assume it already exists and do not create it.
LAKEHOLD_TEST_S3_ENDPOINT=http://localhost:59000
LAKEHOLD_TEST_S3_KEY=lakehold
LAKEHOLD_TEST_S3_SECRET=lakehold123
LAKEHOLD_TEST_S3_BUCKET=lakehold-test

# ---------------------------------------------------------------------------
# Application secrets
#
# Double underscore is the .NET configuration separator: Lakehouse__EjectSigningKey binds to
# Lakehouse:EjectSigningKey.
# ---------------------------------------------------------------------------

# Signs eject manifests with HMAC-SHA256, making the row-count and digest attestation
# tamper-evident. Unset leaves bundles unsigned but still digest-attested. This is a real secret:
# it must never reach a manifest, a response, or a log.
# Lakehouse__EjectSigningKey=change-me-to-something-random

# The shared password for the PostgreSQL wire endpoint (Lakehold:PgWire:Enabled). It is what Power
# BI, Tableau, and psql present, and it authenticates every tenant, so it is as sensitive as the
# catalogs the node serves. Enabling the endpoint without setting this refuses to start — see
# docs/POSTGRES-WIRE.md.
# Lakehold__PgWire__Password=change-me-to-something-random
